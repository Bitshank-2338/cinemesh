# ──────────────────────────────────────────────────────────────────────────────
# CineMesh environment variables
# Copy this file to .env.local and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase (required for cross-device rooms) ────────────────────────────────
# Get these from https://app.supabase.com → Project Settings → API
# Without these, CineMesh falls back to BroadcastChannel which works
# across browser tabs on the SAME device only.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── TURN server (optional — needed for WebRTC across symmetric NATs) ──────────
# Free option: use Metered TURN https://www.metered.ca/
# Without this, WebRTC works on most networks but may fail on strict corporate NAT.
# NEXT_PUBLIC_TURN_URL=turn:your-turn-server.com:3478
# NEXT_PUBLIC_TURN_USERNAME=username
# NEXT_PUBLIC_TURN_CREDENTIAL=credential
